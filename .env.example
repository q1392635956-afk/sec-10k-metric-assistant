# Copy this file to .env and fill in your key.
# Get a free key at https://aistudio.google.com/app/apikey
# Never commit .env to version control.

GEMINI_API_KEY=your_google_ai_studio_api_key_here

# Gemini model to use for classification, extraction, and explanation.
# gemini-2.5-flash-lite is recommended: it is fast, free-tier friendly,
# and fully sufficient because Python handles all financial calculations.
GEMINI_CHAT_MODEL=gemini-2.5-flash-lite
